import { useMemo, useState } from "react";
import { useNavigate } from "react-router-dom";

export default function Home() {
  const navigate = useNavigate();

  const [origin, setOrigin] = useState("LHR");
  const [destination, setDestination] = useState("JFK");
  const [departDate, setDepartDate] = useState("2026-03-10");
  const [adults, setAdults] = useState(1);
  const [currency, setCurrency] = useState("GBP");
  const [loading] = useState(false);

  const canSearch = useMemo(
    () =>
      origin.trim() &&
      destination.trim() &&
      departDate.trim() &&
      adults >= 1,
    [origin, destination, departDate, adults]
  );

  function searchFlights() {
    if (!canSearch || loading) return;

    navigate(
      `/flights?origin=${origin.toUpperCase()}` +
        `&destination=${destination.toUpperCase()}` +
        `&departDate=${departDate}` +
        `&adults=${adults}` +
        `&currency=${currency.toUpperCase()}` +
        `&sort=best`
    );
  }

  return (
    <div style={{ maxWidth: 980, margin: "40px auto", padding: 16 }}>
      <h1>Farely</h1>
      <p style={{ opacity: 0.7 }}>Budget-first flight search.</p>

      <div style={{ display: "grid", gridTemplateColumns: "repeat(6, 1fr)", gap: 10 }}>
        <input value={origin} onChange={(e) => setOrigin(e.target.value)} placeholder="From (IATA)" />
        <input value={destination} onChange={(e) => setDestination(e.target.value)} placeholder="To (IATA)" />
        <input type="date" value={departDate} onChange={(e) => setDepartDate(e.target.value)} />
        <input type="number" min="1" value={adults} onChange={(e) => setAdults(Number(e.target.value))} />
        <input value={currency} onChange={(e) => setCurrency(e.target.value)} />
        <button onClick={searchFlights} disabled={!canSearch}>
          Search
        </button>
      </div>

      <div style={{ marginTop: 16 }}>
        <button onClick={() => navigate("/flights")}>
          Go to Flights →
        </button>
      </div>
    </div>
  );
}
import { useMemo, useState } from "react";
import { useNavigate } from "react-router-dom";

const API_BASE = "http://localhost:3001";

export default function Home() {
  const navigate = useNavigate();

  const [origin, setOrigin] = useState("LHR");
  const [destination, setDestination] = useState("JFK");
  const [departDate, setDepartDate] = useState("2026-03-10");
  const [adults, setAdults] = useState(1);
  const [currency, setCurrency] = useState("GBP");

  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [results, setResults] = useState([]);

  const canSearch = useMemo(
    () => origin.trim() && destination.trim() && departDate.trim() && adults >= 1,
    [origin, destination, departDate, adults]
  );

  async function searchFlights() {
    setLoading(true);
    setError("");
    setResults([]);

    try {
      const url = new URL(`${API_BASE}/api/flights/normalized`);
      url.searchParams.set("origin", origin.toUpperCase());
      url.searchParams.set("destination", destination.toUpperCase());
      url.searchParams.set("departDate", departDate);
      url.searchParams.set("adults", String(adults));
      url.searchParams.set("currency", currency.toUpperCase());

      const resp = await fetch(url.toString());
      const data = await resp.json();

      if (!resp.ok) throw new Error(data?.error || "Request failed");
      setResults(data.results || []);
    } catch (e) {
      setError(e.message || "Something went wrong");
    } finally {
      setLoading(false);
    }
  }

  return (
    <div style={{ maxWidth: 980, margin: "40px auto", padding: 16, fontFamily: "system-ui, -apple-system" }}>
      <h1 style={{ marginBottom: 6 }}>Farely</h1>
      <p style={{ marginTop: 0, opacity: 0.7 }}>Budget-first flight search.</p>

      <div style={{ display: "grid", gridTemplateColumns: "repeat(6, 1fr)", gap: 10, padding: 14, border: "1px solid #e5e5e5", borderRadius: 14 }}>
        <Field label="From (IATA)" value={origin} onChange={setOrigin} />
        <Field label="To (IATA)" value={destination} onChange={setDestination} />
        <Field label="Depart" type="date" value={departDate} onChange={setDepartDate} />
        <Field label="Adults" type="number" value={adults} onChange={(v) => setAdults(Number(v))} min={1} />
        <Field label="Currency" value={currency} onChange={setCurrency} />

        <div style={{ display: "flex", alignItems: "end" }}>
          <button
            onClick={searchFlights}
            disabled={!canSearch || loading}
            style={{
              width: "100%",
              padding: "10px 12px",
              borderRadius: 12,
              border: "1px solid #111",
              background: loading ? "#f5f5f5" : "#111",
              color: loading ? "#111" : "#fff",
              cursor: loading ? "not-allowed" : "pointer",
              fontWeight: 600,
            }}
          >
            {loading ? "Searching…" : "Search"}
          </button>
        </div>
      </div>

      <div style={{ display: "flex", gap: 8, marginTop: 12, flexWrap: "wrap" }}>
        <Preset label="Umrah (LHR→JED)" onClick={() => { setOrigin("LHR"); setDestination("JED"); }} />
        <Preset label="Dubai (LHR→DXB)" onClick={() => { setOrigin("LHR"); setDestination("DXB"); }} />
        <Preset label="NYC (LHR→JFK)" onClick={() => { setOrigin("LHR"); setDestination("JFK"); }} />
      </div>

      {error && (
        <div style={{ marginTop: 14, padding: 12, borderRadius: 12, background: "#fff2f2", border: "1px solid #ffd2d2" }}>
          {error}
        </div>
      )}

      <div style={{ marginTop: 18, display: "grid", gap: 10 }}>
        {results.map((r) => (
          <ResultCard key={r.id} r={r} />
        ))}
      </div>

      {!loading && results.length === 0 && !error && (
        <p style={{ marginTop: 18, opacity: 0.7 }}>
          Tip: Try <b>LHR → DXB</b> or <b>LHR → JFK</b>.
        </p>
      )}

      <div style={{ marginTop: 24 }}>
        <button
          onClick={() => navigate("/flights")}
          style={{ padding: "8px 10px", borderRadius: 999, border: "1px solid #e5e5e5", background: "#fff", cursor: "pointer", fontWeight: 700 }}
        >
          Go to Flights →
        </button>
      </div>
    </div>
  );
}

function Field({ label, type = "text", value, onChange, min }) {
  return (
    <label style={{ display: "grid", gap: 6 }}>
      <span style={{ fontSize: 12, opacity: 0.7 }}>{label}</span>
      <input
        type={type}
        value={value}
        min={min}
        onChange={(e) => onChange(e.target.value)}
        style={{ padding: "10px 10px", borderRadius: 12, border: "1px solid #e5e5e5", outline: "none" }}
      />
    </label>
  );
}

function Preset({ label, onClick }) {
  return (
    <button
      onClick={onClick}
      style={{
        padding: "8px 10px",
        borderRadius: 999,
        border: "1px solid #e5e5e5",
        background: "#fff",
        cursor: "pointer",
        fontWeight: 600,
      }}
    >
      {label}
    </button>
  );
}

function ResultCard({ r }) {
  const price = r.price?.total?.toFixed?.(2) ?? r.price?.total;
  const currency = r.price?.currency;
  const summary = r.display?.summary;

  const originName = r.display?.origin?.name || r.display?.origin?.code;
  const destName = r.display?.destination?.name || r.display?.destination?.code;

  const firstDeparture = r.display?.firstDeparture;
  const lastArrival = r.display?.lastArrival;

  return (
    <div style={{ border: "1px solid #e5e5e5", borderRadius: 14, padding: 14 }}>
      <div style={{ display: "flex", justifyContent: "space-between", gap: 12, flexWrap: "wrap" }}>
        <div>
          <div style={{ fontWeight: 800 }}>{originName} → {destName}</div>
          <div style={{ opacity: 0.75, marginTop: 2 }}>{summary}</div>
          <div style={{ opacity: 0.65, marginTop: 6, fontSize: 13 }}>
            {firstDeparture ? `Depart: ${firstDeparture}` : ""}{" "}
            {lastArrival ? `• Arrive: ${lastArrival}` : ""}
          </div>
        </div>

        <div style={{ fontSize: 22, fontWeight: 900 }}>
          {currency} {price}
        </div>
      </div>
    </div>
  );
}

