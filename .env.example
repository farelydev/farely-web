PORT=4000

# Amadeus API credentials from https://developers.amadeus.com/my-apps
AMADEUS_CLIENT_ID=replace_me
AMADEUS_CLIENT_SECRET=replace_me
AMADEUS_HOSTNAME=test

# Keep demo fallback on while developing. Set to false when you want hard failures.
USE_DEMO_FALLBACK=true

# Deal redirect partner configuration.
# Set TRAVELPAYOUTS_MARKER from your Travelpayouts dashboard to make View deal
# buttons redirect through your affiliate account.
FLIGHT_DEAL_PARTNER=travelpayouts
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_HOST=www.aviasales.com
TRAVELPAYOUTS_SUB_ID=farely

# Optional override if Travelpayouts gives you a specific deep-link template.
# Supported template tokens:
# {origin} {destination} {departureDate} {departureDay} {departureMonth}
# {departureYear} {departureShortYear} {departureCompact}
# {returnDate} {returnDay} {returnMonth} {returnYear} {returnShortYear}
# {returnCompact} {carrier} {offerId} {source} {marker} {subId}
FLIGHT_AFFILIATE_URL=

# Protects /api/analytics/deal-clicks.
# Use a long private value. To unlock the dashboard locally, open:
# http://localhost:5173/?admin=your_private_token#farely-analytics
ADMIN_ANALYTICS_TOKEN=replace_with_a_private_admin_token

# Optional: point Vite's /api proxy at another local backend port.
# VITE_API_TARGET=http://localhost:4000

# Public emails shown in the website UI. Do not use a private forwarding inbox here.
# VITE_CONTACT_EMAIL=info@tryfarely.com
# VITE_SUPPORT_EMAIL=support@tryfarely.com
# VITE_NOREPLY_EMAIL=noreply@tryfarely.com

# Optional support form email forwarding.
# Cloudflare Email Routing receives/forwards mail, but does not send website form emails.
# Add a sending provider such as Resend to automatically forward support form submissions.
# RESEND_API_KEY=
# Public support email returned by the support API. Keep this public even if SUPPORT_TO_EMAIL forwards privately.
# PUBLIC_SUPPORT_EMAIL=support@tryfarely.com
# SUPPORT_TO_EMAIL=info@tryfarely.com
# SUPPORT_FROM_EMAIL=Farely Support <support@tryfarely.com>

# Example only:
# FLIGHT_AFFILIATE_URL=https://example-affiliate-network.com/search?from={origin}&to={destination}&depart={departureDate}&return={returnDate}&marker={marker}
